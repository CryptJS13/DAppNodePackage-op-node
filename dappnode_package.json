  "categories": ["Blockchain"],
  "keywords": ["base", "op-stack", "rollup", "ethereum", "node"],
  "type": "service",
  "architectures": ["linux/amd64", "linux/arm64"],
  "links": {
    "homepage": "https://github.com/CryptJS13/DAppNodePackage-op-node#readme",
    "api": "http://base-op-node.public.dappnode:9545"
  },
  "exposable": [
    {
      "name": "Base OP Node JSON-RPC (HTTP)",
      "description": "HTTP JSON-RPC endpoint for Base rollup node",
      "serviceName": "base-op-node",
      "port": 9545
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptJS13/DAppNodePackage-op-node.git"
  },
  "bugs": {
    "url": "https://github.com/CryptJS13/DAppNodePackage-op-node/issues"
  },
  "license": "GPL-3.0",
  "requirements": {
    "minimumDappnodeVersion": "0.2.80"
  },
  "globalEnvs": [
    {
      "envs": [
        "EXECUTION_CLIENT_MAINNET",
        "CONSENSUS_CLIENT_MAINNET",
        "OP_EXECUTION_CLIENT"
      ],
      "services": ["base-op-node"]
    }
  ]
